[Unit]
Description=HostHive System Agent (root-level operations)
Documentation=https://hosthive.dev
After=network.target hosthive-api.service
Wants=hosthive-api.service

[Service]
Type=simple
# The agent runs as root because it performs privileged system operations
# (creating users, managing services, editing configs, etc.)
User=root
Group=root
WorkingDirectory=/opt/hosthive
EnvironmentFile=/opt/hosthive/config/secrets.env

ExecStart=/opt/hosthive/venv/bin/uvicorn \
    agent.main:app \
    --host 127.0.0.1 \
    --port 7080 \
    --workers 1 \
    --log-level info

Restart=always
RestartSec=5

# The agent binds to localhost only — Nginx restricts external access.
# Even though it runs as root, limit exposure where possible.
NoNewPrivileges=false
PrivateTmp=true

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hosthive-agent

[Install]
WantedBy=multi-user.target
