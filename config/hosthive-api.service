[Unit]
Description=HostHive API Server (uvicorn)
Documentation=https://hosthive.dev
After=network.target postgresql.service redis-server.service
Wants=postgresql.service redis-server.service

[Service]
Type=simple
User=hosthive
Group=hosthive
WorkingDirectory=/opt/hosthive
EnvironmentFile=/opt/hosthive/config/secrets.env
Environment=PYTHONPATH=/opt/hosthive

ExecStart=/opt/hosthive/venv/bin/uvicorn \
    api.main:app \
    --host 127.0.0.1 \
    --port 8000 \
    --workers 2 \
    --log-level info \
    --access-log

Restart=always
RestartSec=5

# Security hardening
NoNewPrivileges=false
ProtectSystem=strict
ProtectHome=false
ReadWritePaths=/opt/hosthive /var/log/hosthive
PrivateTmp=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hosthive-api

[Install]
WantedBy=multi-user.target
