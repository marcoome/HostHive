{# static.j2 -- Static files only, no PHP #}
{% if ssl %}
server {
    listen 80;
    listen [::]:80;

    server_name {{ domain }} www.{{ domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;

    server_name {{ domain }} www.{{ domain }};
    root {{ document_root }};
    index index.html index.htm;

    access_log /var/log/nginx/{{ domain }}.access.log;
    error_log  /var/log/nginx/{{ domain }}.error.log;

    # SSL configuration
    ssl_certificate     {{ ssl_certificate }};
    ssl_certificate_key {{ ssl_certificate_key }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;

    ssl_stapling on;
    ssl_stapling_verify on;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
{% if geo_enabled %}

    # GeoIP geo-blocking (managed by HostHive WAF)
    if ($geo_blocked) {
        return 403;
    }
{% endif %}

    location / {
        try_files $uri $uri/ =404;
    }

    # Deny access to hidden files
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Aggressive caching for static assets
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|woff2?|ttf|svg|eot|webp|avif|mp4|webm)$ {
        expires 365d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Enable gzip for text assets
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml text/javascript image/svg+xml;
    gzip_min_length 256;
{% if custom_error_pages %}

    # Custom error pages
{% for code, page in custom_error_pages.items() %}
    error_page {{ code }} {{ page }};
{% endfor %}
{% endif %}
{% if custom_nginx_config %}

    # Custom directives
{{ custom_nginx_config | indent(4, first=true) }}
{% endif %}
}
{% else %}
